# Database
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/kitep-world?schema=public"

# JWT Secret (генерируйте случайную строку минимум 32 символа)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# SMTP Settings (для отправки email)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# S3 Storage (Twcloud или другой S3-совместимый)
S3_URL="https://s3.twcstorage.ru"
BUCKET_NAME="your-bucket-name"
S3_ACCESS_KEY="YOUR_ACCESS_KEY"
S3_SECRET_ACCESS_KEY="YOUR_SECRET_ACCESS_KEY"

# OpenAI API (для AI функционала)
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_API_KEY"

# Finik Pay (платежная система)
FINIK_ENV="prod"
FINIK_API_KEY="YOUR_FINIK_API_KEY"
FINIK_ACCOUNT_ID="YOUR_FINIK_ACCOUNT_ID"
FINIK_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_FINIK_PRIVATE_KEY
-----END PRIVATE KEY-----"

# Telegram Bot (для уведомлений админов)
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"
TELEGRAM_ADMIN_USER_ID="YOUR_TELEGRAM_USER_ID"

# Google OAuth (опционально, для входа через Google)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Next.js Public URL
NEXT_PUBLIC_APP_URL="https://your-domain.com/"
