generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admin_verifications {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  code       String   @db.VarChar(6)
  expires_at DateTime @db.Timestamp(6)
  verified   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, code])
}

model ai_chats {
  id          String        @id @db.Uuid
  name        String        @db.VarChar(255)
  user_id     String?       @db.Uuid
  created_at  DateTime      @default(now()) @db.Timestamp(6)
  users       users?        @relation(fields: [user_id], references: [id])
  ai_messages ai_messages[]
}

model ai_messages {
  id         String        @id @db.Uuid
  chat_id    String        @db.Uuid
  sender     MessageSender
  message    String
  created_at DateTime      @default(now()) @db.Timestamp(6)
  ai_chats   ai_chats      @relation(fields: [chat_id], references: [id], onDelete: Cascade)
}

model BannerTranslation {
  id        String  @id @default(uuid()) @db.Uuid
  bannerId  String  @map("banner_id") @db.Uuid
  locale    Locale
  title     String  @db.VarChar(255)
  
  // Relations
  banner    Banner  @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@unique([bannerId, locale])
  @@map("banner_translations")
}

model Banner {
  id                  String                @id @default(uuid()) @db.Uuid
  url                 String?               @db.Text
  status              BannerStatus          @default(active)
  desktopImage        String                @map("desktop_image") @db.Text
  mobileImage         String                @map("mobile_image") @db.Text
  
  // Relations
  translations        BannerTranslation[]

  @@map("banners")
}

model branch_inventory {
  id         String   @id @db.Uuid
  branch_id  String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Int      @default(0)
  updated_at DateTime @db.Timestamp(6)
  branches   branches @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([branch_id, product_id])
}

model branch_users {
  id        String   @id @db.Uuid
  branch_id String   @db.Uuid
  user_id   String   @db.Uuid
  branches  branches @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([branch_id, user_id])
}

model branches {
  id               String             @id @db.Uuid
  name             String             @db.VarChar(255)
  code             String             @unique @db.VarChar(50)
  city             String             @db.VarChar(100)
  district         String             @db.VarChar(100)
  address          String
  phone            String             @db.VarChar(30)
  email            String             @db.VarChar(255)
  latitude         Decimal?           @db.Decimal(10, 7)
  longitude        Decimal?           @db.Decimal(10, 7)
  open_time        DateTime?          @db.Time(6)
  close_time       DateTime?          @db.Time(6)
  status           BranchStatus       @default(active)
  created_at       DateTime           @default(now()) @db.Timestamp(6)
  updated_at       DateTime           @db.Timestamp(6)
  work_days        String[]           @default([])
  branch_inventory branch_inventory[]
  branch_users     branch_users[]
  orders           orders[]
}

model carts {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Int      @default(1)
  created_at DateTime @default(now()) @db.Timestamp(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
}

model categories {
  id                    String                  @id @db.Uuid
  parent_id             String?                 @db.Uuid
  image                 String?
  status                CategoryStatus          @default(active)
  categories            categories?             @relation("categoriesTocategories", fields: [parent_id], references: [id])
  other_categories      categories[]            @relation("categoriesTocategories")
  category_translations category_translations[]
  products              products[]
}

model category_translations {
  id          String     @id @db.Uuid
  category_id String     @db.Uuid
  locale      Locale
  name        String     @db.VarChar(255)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, locale])
}

model email_verifications {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  email      String   @db.VarChar(255)
  code       String   @db.VarChar(6)
  expires_at DateTime @db.Timestamp(6)
  verified   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([email, code])
}

model order_items {
  id         String   @id @db.Uuid
  order_id   String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Int
  total      Decimal  @db.Decimal(12, 2)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  products   products @relation(fields: [product_id], references: [id])
}

model orders {
  id             String        @id @db.Uuid
  order_number   String        @unique @db.VarChar(50)
  user_id        String        @db.Uuid
  branch_id      String        @db.Uuid
  comment        String?
  total          Decimal       @db.Decimal(12, 2)
  payment_status PaymentStatus
  order_status   OrderStatus   @default(paid)
  created_at     DateTime      @default(now()) @db.Timestamp(6)
  order_items    order_items[]
  branches       branches      @relation(fields: [branch_id], references: [id])
  users          users         @relation(fields: [user_id], references: [id])
  payments       payments[]
}

model password_resets {
  id         String   @id @db.Uuid
  email      String   @db.VarChar(255)
  code       String   @db.VarChar(6)
  expires_at DateTime @db.Timestamp(6)
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@index([email, code])
}

model payments {
  id             String   @id @db.Uuid
  order_id       String   @db.Uuid
  provider       String   @db.VarChar(50)
  transaction_id String   @db.VarChar(255)
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @db.VarChar(10)
  status         String   @db.VarChar(50)
  raw_response   Json?
  paid_at        DateTime @db.Timestamp(6)
  orders         orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model product_attributes {
  id         String   @id @db.Uuid
  product_id String   @db.Uuid
  name       String   @db.VarChar(255)
  value      String   @db.VarChar(255)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model product_images {
  id         String      @id @db.Uuid
  product_id String      @db.Uuid
  image_url  String
  status     ImageStatus @default(active)
  products   products    @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model product_translations {
  id          String   @id @db.Uuid
  product_id  String   @db.Uuid
  locale      Locale
  name        String   @db.VarChar(255)
  description String?
  products    products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, locale])
}

model products {
  id                   String                 @id @db.Uuid
  sku                  String                 @unique @db.VarChar(100)
  category_id          String                 @db.Uuid
  brand                String?                @db.VarChar(255)
  price                Decimal                @db.Decimal(12, 2)
  status               ProductStatus          @default(active)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  updated_at           DateTime               @db.Timestamp(6)
  branch_inventory     branch_inventory[]
  carts                carts[]
  order_items          order_items[]
  product_attributes   product_attributes[]
  product_images       product_images[]
  product_translations product_translations[]
  categories           categories             @relation(fields: [category_id], references: [id])
  reviews              reviews[]
}

model reviews {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  product_id String   @db.Uuid
  rating     Int      @db.SmallInt
  comment    String?
  created_at DateTime @default(now()) @db.Timestamp(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
}

model settings {
  id    String @id @db.Uuid
  key   String @unique @db.VarChar(255)
  value String
}

model users {
  id                  String                @id @db.Uuid
  full_name           String                @db.VarChar(255)
  email               String                @unique @db.VarChar(255)
  role                UserRole              @default(user)
  phone               String?               @unique @db.VarChar(30)
  password_hash       String
  google_id           String?               @db.VarChar(255)
  avatar              String?
  status              UserStatus            @default(active)
  created_at          DateTime              @default(now()) @db.Timestamp(6)
  updated_at          DateTime              @db.Timestamp(6)
  email_verified      Boolean               @default(false)
  admin_verifications admin_verifications[]
  ai_chats            ai_chats[]
  branch_users        branch_users[]
  carts               carts[]
  email_verifications email_verifications[]
  orders              orders[]
  reviews             reviews[]
}

enum BannerStatus {
  active
  inactive
}

enum BranchStatus {
  active
  inactive
  deleted
}

enum CategoryStatus {
  active
  inactive
  deleted
}

enum ImageStatus {
  active
  inactive
  deleted
}

enum Locale {
  ru
  kg
}

enum MessageSender {
  user
  ai
}

enum OrderStatus {
  paid
  completed
  cancelled
}

enum PaymentStatus {
  success
  failed
}

enum ProductStatus {
  active
  inactive
  deleted
}

enum UserRole {
  admin
  user
  manager
}

enum UserStatus {
  active
  inactive
  blocked
}
